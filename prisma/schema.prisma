// Enable postgresqlExtensions to natively support pgvector
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Example model to validate the vector extension
model Document {
  id        Int                         @id @default(autoincrement())
  title     String
  // Dimensions depend on the embedding model (e.g., Gemini)
  embedding Unsupported("vector(768)")?
}
