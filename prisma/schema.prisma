generator client {
  provider = "prisma-client"

  output = "../backend/generated/prisma"

  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model Document {
  id        Int                         @id @default(autoincrement())
  title     String
  embedding Unsupported("vector(768)")?
}
